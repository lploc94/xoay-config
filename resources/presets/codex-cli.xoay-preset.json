{
  "$schema": "xoay-preset/v1",
  "id": "codex-cli",
  "name": "Codex CLI",
  "description": "Config items for Codex CLI (config.toml + auth.json)",
  "categoryName": "Codex CLI",
  "defaultItems": [
    {
      "type": "file-replace",
      "label": "Codex config.toml",
      "enabled": true,
      "targetPath": "~/.codex/config.toml"
    },
    {
      "type": "file-replace",
      "label": "Codex auth.json",
      "enabled": true,
      "targetPath": "~/.codex/auth.json"
    }
  ],
  "hooks": [
    {
      "label": "Codex Quota Check",
      "type": "cron",
      "cronIntervalMs": 60000,
      "scriptFile": "codex-quota.js"
    }
  ],
  "scripts": {
    "codex-quota.js": ""
  }
}
